{{/* First-run prompts. Answers stored in ~/.config/chezmoi/chezmoi.toml.
     This template runs on `chezmoi init`, then values are reused by every
     other template via `.flavor`, `.email`, etc. */ -}}

{{- $flavor   := promptStringOnce . "flavor"   "Machine flavor (work|personal)" "personal" -}}
{{- $fullName := promptStringOnce . "fullName" "Full name for git commits"      "Naseer Basma" -}}
{{- $email    := promptStringOnce . "email"    "Email for git commits"          "" -}}
{{- $opVault  := promptStringOnce . "op_vault" "1Password vault name for this flavor" (eq $flavor "work" | ternary "Work" "Personal") -}}
{{- $workGitlabHost := "" -}}
{{- if eq $flavor "work" -}}
{{-   $workGitlabHost = promptStringOnce . "work_gitlab_host" "Work GitLab host FQDN (e.g. gitlab.internal.acme.co.uk)" "" -}}
{{- end -}}

[data]
    flavor           = {{ $flavor | quote }}
    fullName         = {{ $fullName | quote }}
    email            = {{ $email | quote }}
    op_vault         = {{ $opVault | quote }}
    work_gitlab_host = {{ $workGitlabHost | quote }}
