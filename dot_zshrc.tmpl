# ~/.zshrc — managed by chezmoi.
# Source of truth: ~/Dev/dotfiles/dot_zshrc.tmpl
# Quick edit: `chezmoi edit ~/.zshrc`, then `chezmoi apply`

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Theme + plugins
ZSH_THEME="robbyrussell"
plugins=(git)

source $ZSH/oh-my-zsh.sh

# Java (guarded — only set if Java 21 is installed)
if /usr/libexec/java_home -v 21 >/dev/null 2>&1; then
    export JAVA_HOME="$(/usr/libexec/java_home -v 21)"
    export PATH="$JAVA_HOME/bin:$PATH"
fi

# Local bin
export PATH="$HOME/.local/bin:$PATH"

# pyenv + pyenv-virtualenv (guarded — only set up if installed)
export PYENV_ROOT="$HOME/.pyenv"
if [[ -d $PYENV_ROOT/bin ]]; then
    export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init --path)"
    eval "$(pyenv init -)"
    command -v pyenv-virtualenv-init >/dev/null 2>&1 && eval "$(pyenv virtualenv-init -)"
fi

# ===== Common aliases =====
alias zshconfig='nvim ~/.zshrc'
alias ohmyzsh='nvim ~/.oh-my-zsh'
alias nzshrc='nano ~/.zshrc'
alias grep='grep --color=auto'
alias ls='ls --color=auto'
alias l='ls -lth --color=auto'
alias ll='ls -lthra --color=auto'
alias lhead='ls -lth --color=auto | head'
alias nn='nano'
alias vi='vim'
alias c='clear'
alias h='history'

# git aliases
alias g='git'
alias ga='git add'
alias gc='git commit'
alias gcm='git commit -m'
alias gph='git push'
alias gphf='git push --force'
alias gpl='git pull'
alias gr='git rm'
alias gf='git fetch'
alias gs='git status'
alias gb='git branch'
alias gcl='git clone'
alias gch='git checkout'
alias gchb='git checkout -b'
alias gchm='git checkout main'
alias gst='git stash'
alias gstp='git stash pop'
alias gstsh='git stash show'
alias gsta='git stash apply'
alias gstl='git stash list'
alias gstcl='git stash clear'
alias gstshl='git stash show -l'
alias groot='cd "$(git rev-parse --show-toplevel)"'
alias lgroot='ls -lth --color=auto "$(git rev-parse --show-toplevel)"'

# AWS CLI aliases (account-agnostic — work for any configured profile)
alias awswho='aws sts get-caller-identity'
alias awsls='aws s3 ls'
alias awsrm='aws s3 rm'
alias awsrmr='aws s3 rm --recursive'

# Misc
alias py-server='python -m http.server'
alias caff='caffeinate -d &'
alias decaf='pkill caffeinate'

# ===== Common shell functions =====
run_in_docker() {
    docker run --rm -it -w "$PWD" -u "$(id -u)" -v "${PWD}:${PWD}" -v "$HOME/.aws:${PWD}/.aws" -e "HOME=$PWD" --entrypoint bash "$1"
}

hgrep() {
    history | grep "$1"
}

nfcleanx() {
    local times="$1"
    if [ -z "$times" ]; then
        echo "Usage: nfcleanx <number_of_times>"
        return 1
    fi
    for ((i=1; i<=$times; i++)); do
        echo "Running clean $i of $times"
        nextflow clean -f
    done
}

s3_bucket_size() {
    if [ -z "$1" ]; then
        echo "Usage: s3_bucket_size <bucket-name>"
        return 1
    fi
    aws s3 ls "$1" --recursive --human-readable --summarize | grep "Total Size" | awk '{print $3, $4}'
}

du_sort() {
    local depth="${1:-1}"
    gdu -h --max-depth=$depth | gsort -hr
}

# ===== chezmoi-managed flavor block =====
