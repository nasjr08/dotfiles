#!/usr/bin/env bash
# Install all Homebrew packages, casks, and Mac App Store apps.
# Re-runs when content of packages/Brewfile, packages/Brewfile.personal.tmpl,
# or packages/Brewfile.work.tmpl changes.
#
# Content fingerprint (forces re-run on edit):
{{- $brewfile := joinPath .chezmoi.sourceDir "packages" "Brewfile" }}
{{- $brewfilePersonal := joinPath .chezmoi.sourceDir "packages" "Brewfile.personal.tmpl" }}
{{- $brewfileWork := joinPath .chezmoi.sourceDir "packages" "Brewfile.work.tmpl" }}
# Brewfile sha256:          {{ sha256sum (include $brewfile) }}
# Brewfile.personal sha256: {{ sha256sum (include $brewfilePersonal) }}
# Brewfile.work sha256:     {{ sha256sum (include $brewfileWork) }}

set -euo pipefail

SRC="{{ .chezmoi.sourceDir }}"

# Run brew bundle without letting one bad entry abort the whole bootstrap — e.g.
# a flaky cask download (microsoft-teams' CDN) or a GUI app corporate IT already
# installs (Slack, Office, Cursor, VS Code...). brew bundle exits non-fatally so
# later lifecycle scripts (macOS defaults, etc.) still run. Failures are logged
# loudly rather than hidden.
brew_bundle_nonfatal() {
  local file="$1" label="$2"
  if ! brew bundle --file="$file"; then
    echo "[brews] ⚠️  WARNING: some '$label' Brewfile entries failed (see above)." >&2
    echo "[brews]     Non-fatal — continuing. Re-run 'chezmoi apply' or install by hand." >&2
  fi
}

echo "[brews] running brew bundle for common Brewfile"
brew_bundle_nonfatal "$SRC/packages/Brewfile" "common"

{{ if eq .flavor "personal" -}}
echo "[brews] rendering and applying Brewfile.personal"
TMP_BREWFILE_PERSONAL="$(mktemp)"
trap 'rm -f "$TMP_BREWFILE_PERSONAL"' EXIT
chezmoi execute-template < "$SRC/packages/Brewfile.personal.tmpl" > "$TMP_BREWFILE_PERSONAL"
brew_bundle_nonfatal "$TMP_BREWFILE_PERSONAL" "personal"
{{- end }}

{{ if eq .flavor "work" -}}
echo "[brews] trusting taps declared in Brewfile.work"
# Homebrew >=4.4 requires explicit trust per third-party tap. Without this,
# `brew bundle` silently skips any formula/cask/command from these taps and
# the install appears to succeed while leaving things missing. Add new taps
# here in lockstep with adding `tap "..."` lines to Brewfile.work.tmpl.
brew trust supabase/tap
brew trust hashicorp/tap

echo "[brews] rendering and applying Brewfile.work"
TMP_BREWFILE_WORK="$(mktemp)"
trap 'rm -f "$TMP_BREWFILE_WORK"' EXIT
chezmoi execute-template < "$SRC/packages/Brewfile.work.tmpl" > "$TMP_BREWFILE_WORK"
brew_bundle_nonfatal "$TMP_BREWFILE_WORK" "work"
{{- end }}

echo "[brews] done"
